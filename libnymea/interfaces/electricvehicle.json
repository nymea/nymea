{
    "description": "Interface for electric vehicles with common battery, charging capability and session states.",
    "extends": ["battery"],
    "states": [
        {
            "name": "capacity",
            "type": "double",
            "unit": "KiloWattHour",
            "optional": true
        },
        {
            "name": "chargingInterfaces",
            "type": "QString",
            "allowedValues": ["ac", "dc", "acdc"],
            "optional": true
        },
        {
            "name": "activeChargingInterface",
            "type": "QString",
            "allowedValues": ["ac", "dc"],
            "optional": true,
            "logged": false
        },
        {
            "name": "connectedChargerThingId",
            "type": "QString",
            "optional": true,
            "logged": false
        },
        {
            "name": "acMinChargingCurrent",
            "type": "uint",
            "unit": "Ampere",
            "minValue": 6,
            "maxValue": 16,
            "optional": true
        },
        {
            "name": "acMaxChargingCurrent",
            "type": "uint",
            "unit": "Ampere",
            "minValue": 16,
            "maxValue": 80,
            "optional": true
        },
        {
            "name": "acPhaseCount",
            "type": "uint",
            "minValue": 1,
            "maxValue": 3,
            "optional": true
        },
        {
            "name": "dcMaxChargingPower",
            "type": "double",
            "unit": "Watt",
            "optional": true
        }
    ]
}
